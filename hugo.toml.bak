baseURL = "https://midwestsec.com/"
languageCode = "en-us"
title = "MidwestSec"
theme = "hugo-theme-stack"

[pagination]
  pagerSize = 10

[params]
  mainSections = ["posts"]
  featuredImageField = "image"
  rssFullContent = true

custom_css = ["scss/custom.scss"]

[params.sidebar]
  subtitle = "Cybersecurity"

[params.article]
  math = false
  toc = false
  readingTime = true

